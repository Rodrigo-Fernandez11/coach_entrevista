# ---------------------------------------------------------
# Interview Coach -- Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.
# ---------------------------------------------------------

# -- Supabase ---------------------------------------------
# Your Supabase project URL (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# Service role key (Project Settings -> API) -- keep secret
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -- Database (Prisma) ------------------------------------
# Pooled URL via PgBouncer (port 6543) -- used at runtime
DATABASE_URL=postgresql://postgres.your-project-ref:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
# Direct URL (port 5432) -- used by prisma migrate
DIRECT_URL=postgresql://postgres.your-project-ref:password@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# -- OpenAI -----------------------------------------------
# Get your key at https://platform.openai.com/api-keys
# Set a monthly spending limit in Billing -> Usage limits first!
OPENAI_API_KEY=sk-proj-...

# -- Trial / cost-protection ------------------------------
# Max AI feedback calls allowed per trial cookie (default 1)
TRIAL_MAX_FEEDBACK=1
# Daily hard cap across all users (default 50)
DAILY_FEEDBACK_CAP=50
# Salt for IP hashing -- generate with: openssl rand -hex 32
IP_HASH_SALT=your-random-salt-here
